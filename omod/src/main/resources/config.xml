<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC "-//OpenMRS//DTD OpenMRS Config 1.6//EN"
        "https://resources.openmrs.org/doctype/config-1.6.dtd">

<module configVersion="1.6">

    <id>${project.parent.artifactId}</id>
    <name>${project.parent.name}</name>
    <version>${project.parent.version}</version>
    <package>org.openmrs.module.querystore</package>
    <author>OpenMRS</author>
    <description>${project.parent.description}</description>

    <activator>org.openmrs.module.querystore.QueryStoreActivator</activator>

    <require_version>2.8.0</require_version>

    <!-- The webservices.rest module hosts the /ws/rest/v1 dispatcher that serves the indexing-status
         REST controller (org.openmrs.module.querystore.web.rest). -->
    <require_modules>
        <require_module version="2.44.0">org.openmrs.module.webservices.rest</require_module>
    </require_modules>

    <!--
        Migration-bridge advice per ADR Decision 12. Each entry projects writes through the same
        serialize → embed → index pipeline an events-first handler will drive once core publishes
        the corresponding events. Bridge entries are time-bound: delete the entry (and the advice
        class) when the events subscriber for that type ships and has been verified at parity.
    -->
    <advice>
        <point>org.openmrs.api.ObsService</point>
        <class>org.openmrs.module.querystore.bridge.ObsIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.EncounterService</point>
        <class>org.openmrs.module.querystore.bridge.EncounterIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.ConditionService</point>
        <class>org.openmrs.module.querystore.bridge.ConditionIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.DiagnosisService</point>
        <class>org.openmrs.module.querystore.bridge.DiagnosisIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.VisitService</point>
        <class>org.openmrs.module.querystore.bridge.VisitIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.PatientService</point>
        <class>org.openmrs.module.querystore.bridge.AllergyIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.PatientService</point>
        <class>org.openmrs.module.querystore.bridge.PatientIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.ProgramWorkflowService</point>
        <class>org.openmrs.module.querystore.bridge.PatientProgramIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.MedicationDispenseService</point>
        <class>org.openmrs.module.querystore.bridge.MedicationDispenseIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.OrderService</point>
        <class>org.openmrs.module.querystore.bridge.DrugOrderIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.OrderService</point>
        <class>org.openmrs.module.querystore.bridge.TestOrderIndexingAdvice</class>
    </advice>
    <advice>
        <point>org.openmrs.api.OrderService</point>
        <class>org.openmrs.module.querystore.bridge.ReferralOrderIndexingAdvice</class>
    </advice>

    <updateURL>https://modules.openmrs.org/modules/download/${project.parent.artifactId}/update.rdf</updateURL>

    <globalProperty>
        <property>querystore.syncMode</property>
        <defaultValue>events</defaultValue>
        <description>Active sync path (ADR Decision 12). "events" (default) consumes core's #6084
            *ServiceEvents and gates the bridge off; "aop" runs the migration-bridge advice instead;
            "both" runs both for parity verification only (double embedding cost — not a steady
            state). Read once at startup and cached; a change takes effect on the next module/server
            restart.</description>
    </globalProperty>

    <globalProperty>
        <property>querystore.embedding.providerBean</property>
        <defaultValue>querystore.embedding.onnx</defaultValue>
        <description>Spring bean name of the active EmbeddingProvider. Modules may register
            additional EmbeddingProvider beans, but selecting which is active is a deployment
            decision. See ADR Decision 8.</description>
    </globalProperty>

    <globalProperty>
        <property>querystore.embedding.modelFilePath</property>
        <defaultValue></defaultValue>
        <description>Path (relative to the OpenMRS application data directory) to the ONNX model
            file used by the default embedding provider. Required when the ONNX provider is
            active. The model must be multilingual per ADR Decision 8.</description>
    </globalProperty>

    <globalProperty>
        <property>querystore.embedding.queryModelFilePath</property>
        <defaultValue></defaultValue>
        <description>Optional path to a separate query-encoder ONNX model. Set only for
            dual-encoder models such as MedCPT; leave empty for single-encoder models.</description>
    </globalProperty>

    <globalProperty>
        <property>querystore.embedding.vocabFilePath</property>
        <defaultValue></defaultValue>
        <description>Path (relative to the OpenMRS application data directory) to the WordPiece
            vocabulary file (vocab.txt) for the configured ONNX model.</description>
    </globalProperty>

    <globalProperty>
        <property>querystore.embedding.maxSequenceLength</property>
        <defaultValue>512</defaultValue>
        <description>Maximum number of tokens passed to the embedding model. Inputs beyond this
            length are silently truncated; the chunking layer above the tokenizer is the right
            place to redesign that behavior.</description>
    </globalProperty>

    <globalProperty>
        <property>querystore.bootstrap.autostart</property>
        <defaultValue>false</defaultValue>
        <description>Set to true to run (or resume) a read-store bootstrap when this module starts.
            Default false. After the initial bootstrap completes, subsequent restarts with this flag
            true perform an incremental top-up from each type's persisted cursor. Bootstrap can also
            be triggered programmatically via BootstrapService regardless of this flag.</description>
    </globalProperty>

</module>
