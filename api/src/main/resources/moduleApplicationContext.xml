<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-4.3.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-4.3.xsd
           http://www.springframework.org/schema/tx
           http://www.springframework.org/schema/tx/spring-tx-4.3.xsd">

    <bean id="querystore.backend.mysql"
          class="org.openmrs.module.querystore.backend.mysql.MysqlBackendStore">
        <constructor-arg ref="dataSource"/>
    </bean>

    <bean id="querystore.backend.lucene"
          class="org.openmrs.module.querystore.backend.lucene.LuceneBackendStore"
          destroy-method="close"/>

    <bean id="querystore.backend.selector"
          class="org.openmrs.module.querystore.backend.BackendStoreSelector">
        <constructor-arg>
            <map>
                <entry key="mysql" value-ref="querystore.backend.mysql"/>
                <entry key="lucene" value-ref="querystore.backend.lucene"/>
            </map>
        </constructor-arg>
    </bean>

    <bean id="querystore.backend"
          factory-bean="querystore.backend.selector"
          factory-method="getStore"/>

    <bean id="querystore.embedding.onnx"
          class="org.openmrs.module.querystore.embedding.OnnxEmbeddingProvider"/>

    <bean id="querystore.embedding.dispatcher"
          class="org.openmrs.module.querystore.embedding.ConfiguredEmbeddingProvider"/>

    <bean id="querystore.serializer.obs"
          class="org.openmrs.module.querystore.serialization.ObsRecordSerializer"/>

    <bean id="querystore.serializer.encounter"
          class="org.openmrs.module.querystore.serialization.EncounterRecordSerializer"/>

    <bean id="querystore.serializer.visit"
          class="org.openmrs.module.querystore.serialization.VisitRecordSerializer"/>

    <bean id="querystore.serializer.patient"
          class="org.openmrs.module.querystore.serialization.PatientRecordSerializer"/>

    <bean id="querystore.serializer.condition"
          class="org.openmrs.module.querystore.serialization.ConditionRecordSerializer"/>

    <bean id="querystore.serializer.diagnosis"
          class="org.openmrs.module.querystore.serialization.DiagnosisRecordSerializer"/>

    <bean id="querystore.serializer.allergy"
          class="org.openmrs.module.querystore.serialization.AllergyRecordSerializer"/>

    <bean id="querystore.serializer.drug_order"
          class="org.openmrs.module.querystore.serialization.DrugOrderRecordSerializer"/>

    <bean id="querystore.serializer.test_order"
          class="org.openmrs.module.querystore.serialization.TestOrderRecordSerializer"/>

    <bean id="querystore.serializer.referral_order"
          class="org.openmrs.module.querystore.serialization.ReferralOrderRecordSerializer"/>

    <bean id="querystore.serializer.medication_dispense"
          class="org.openmrs.module.querystore.serialization.MedicationDispenseRecordSerializer"/>

    <bean id="querystore.serializer.program"
          class="org.openmrs.module.querystore.serialization.PatientProgramRecordSerializer"/>

    <bean id="queryStoreService"
          class="org.openmrs.module.querystore.api.impl.QueryStoreServiceImpl">
        <property name="backend" ref="querystore.backend"/>
        <property name="embeddingProvider" ref="querystore.embedding.dispatcher"/>
    </bean>

    <bean id="querystore.bootstrap.progressDao"
          class="org.openmrs.module.querystore.bootstrap.BootstrapProgressDao">
        <constructor-arg ref="dataSource"/>
    </bean>

    <bean id="querystore.bootstrap.obs"
          class="org.openmrs.module.querystore.bootstrap.ObsBootstrapper">
        <constructor-arg ref="querystore.serializer.obs"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.encounter"
          class="org.openmrs.module.querystore.bootstrap.EncounterBootstrapper">
        <constructor-arg ref="querystore.serializer.encounter"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.visit"
          class="org.openmrs.module.querystore.bootstrap.VisitBootstrapper">
        <constructor-arg ref="querystore.serializer.visit"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.patient"
          class="org.openmrs.module.querystore.bootstrap.PatientBootstrapper">
        <constructor-arg ref="querystore.serializer.patient"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.condition"
          class="org.openmrs.module.querystore.bootstrap.ConditionBootstrapper">
        <constructor-arg ref="querystore.serializer.condition"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.diagnosis"
          class="org.openmrs.module.querystore.bootstrap.DiagnosisBootstrapper">
        <constructor-arg ref="querystore.serializer.diagnosis"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.allergy"
          class="org.openmrs.module.querystore.bootstrap.AllergyBootstrapper">
        <constructor-arg ref="querystore.serializer.allergy"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.drug_order"
          class="org.openmrs.module.querystore.bootstrap.DrugOrderBootstrapper">
        <constructor-arg ref="querystore.serializer.drug_order"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.test_order"
          class="org.openmrs.module.querystore.bootstrap.TestOrderBootstrapper">
        <constructor-arg ref="querystore.serializer.test_order"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.referral_order"
          class="org.openmrs.module.querystore.bootstrap.ReferralOrderBootstrapper">
        <constructor-arg ref="querystore.serializer.referral_order"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.medication_dispense"
          class="org.openmrs.module.querystore.bootstrap.MedicationDispenseBootstrapper">
        <constructor-arg ref="querystore.serializer.medication_dispense"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bootstrap.program"
          class="org.openmrs.module.querystore.bootstrap.PatientProgramBootstrapper">
        <constructor-arg ref="querystore.serializer.program"/>
        <constructor-arg ref="dbSessionFactory"/>
    </bean>

    <bean id="querystore.bridge.executor"
          class="org.openmrs.module.querystore.bridge.BridgeExecutor"
          init-method="start" destroy-method="stop"/>

    <bean id="querystore.bridge.dispatcher"
          class="org.openmrs.module.querystore.bridge.AfterCommitDispatcher">
        <constructor-arg ref="querystore.bridge.executor"/>
    </bean>

    <bean id="querystore.bridge.indexer"
          class="org.openmrs.module.querystore.bridge.BridgeIndexer">
        <constructor-arg ref="queryStoreService"/>
        <constructor-arg ref="querystore.embedding.dispatcher"/>
    </bean>

    <bean id="bootstrapService"
          class="org.openmrs.module.querystore.bootstrap.BootstrapServiceImpl">
        <property name="progressDao" ref="querystore.bootstrap.progressDao"/>
        <property name="queryStoreService" ref="queryStoreService"/>
        <property name="embeddingProvider" ref="querystore.embedding.dispatcher"/>
        <property name="bootstrappers">
            <!--
                Order matters operationally: obs typically dwarfs every other type combined (often
                100-1000x), so it runs last. If a bootstrap is interrupted mid-obs, the 11 smaller
                types are already projected and chartsearchai's queries against conditions, orders,
                diagnoses, etc. all work; only obs is incomplete.
            -->
            <list>
                <ref bean="querystore.bootstrap.patient"/>
                <ref bean="querystore.bootstrap.encounter"/>
                <ref bean="querystore.bootstrap.visit"/>
                <ref bean="querystore.bootstrap.condition"/>
                <ref bean="querystore.bootstrap.diagnosis"/>
                <ref bean="querystore.bootstrap.allergy"/>
                <ref bean="querystore.bootstrap.drug_order"/>
                <ref bean="querystore.bootstrap.test_order"/>
                <ref bean="querystore.bootstrap.referral_order"/>
                <ref bean="querystore.bootstrap.medication_dispense"/>
                <ref bean="querystore.bootstrap.program"/>
                <ref bean="querystore.bootstrap.obs"/>
            </list>
        </property>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list>
                <value>org.openmrs.module.querystore.api.QueryStoreService</value>
                <ref bean="queryStoreService"/>
                <value>org.openmrs.module.querystore.bootstrap.BootstrapService</value>
                <ref bean="bootstrapService"/>
            </list>
        </property>
    </bean>

</beans>
